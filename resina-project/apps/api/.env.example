# RESINA API Server Configuration

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# StormGlass Tide API
STORMGLASS_API_KEY=your-stormglass-api-key

# OpenWeather API (for weather automation)
OPENWEATHER_API_KEY=your-openweather-api-key
SENSOR_INGEST_SECRET=your-sensor-ingest-secret
UNISMS_API_KEY=your-unisms-api-key
UNISMS_SMS_DISABLED=true
UNISMS_SENDER_NAME=RESINA

# Optional: direct PAGASA TCB PDF URL override for signal parsing.
# If omitted, the script attempts to auto-discover latest bulletin PDF.
PAGASA_TCB_PDF_URL=

# Server
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
