{
  "expo": {
    "name": "RESINA",
    "slug": "resina-mobile",
    "scheme": "resina",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.resina.mobile"
    },
    "android": {
      "package": "com.resina.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "66ce1dbc-cb55-4f56-aa90-71f106cd95a4"
      }
    },
    "plugins": [
      "@react-native-community/datetimepicker"
    ]
  }
}
